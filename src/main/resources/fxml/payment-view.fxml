<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefHeight="720.0" prefWidth="1100.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.PaymentController"
      stylesheets="@../css/payment-style.css"
      styleClass="root">

    <HBox alignment="CENTER_LEFT" spacing="28.0" styleClass="header">
        <padding>
            <Insets top="14.0" right="28.0" bottom="14.0" left="28.0" />
        </padding>

        <StackPane styleClass="logo-shell">
            <ImageView fitHeight="46.0" pickOnBounds="true" preserveRatio="true" smooth="true" styleClass="logo-image">
                <image>
                    <Image url="@../images/logo.png" />
                </image>
            </ImageView>
        </StackPane>

        <HBox alignment="CENTER_LEFT" spacing="14.0" HBox.hgrow="ALWAYS">
            <Button mnemonicParsing="false" onAction="#abrirAgenda" styleClass="nav-button" text="Agenda" />
            <Button mnemonicParsing="false" onAction="#abrirPacientes" styleClass="nav-button" text="Pacientes" />
            <Button mnemonicParsing="false" styleClass="nav-button-active" text="Faturacao" />
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <Button mnemonicParsing="false" styleClass="icon-button">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M15 17h5l-1.4-1.4c-.4-.4-.6-.9-.6-1.4V11c0-2.8-1.9-5.2-4.5-5.9V4.5a1.5 1.5 0 0 0-3 0v.6C7.9 5.8 6 8.2 6 11v3.2c0 .5-.2 1-.6 1.4L4 17h5m6 0a3 3 0 0 1-6 0" styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>

            <VBox alignment="CENTER_RIGHT" spacing="2.0">
                <Label fx:id="nomeUtilizador" styleClass="user-name" text="Joana Silva" />
                <Label styleClass="user-role" text="Rececionista" />
            </VBox>

            <Button mnemonicParsing="false" onAction="#fazerLogout" styleClass="icon-button">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M15 3h3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-3M10 17l5-5-5-5M15 12H4" styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <HBox spacing="0.0" VBox.vgrow="ALWAYS">
        <VBox spacing="20.0" styleClass="main-content" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="24.0" right="36.0" bottom="24.0" left="36.0" />
            </padding>

            <TextField fx:id="pesquisarField"
                       promptText="Pesquisar por nome ou NIF"
                       styleClass="search-field" />

            <Label styleClass="section-title" text="CONSULTAS CONCLUIDAS" />

            <ListView fx:id="consultasListView" styleClass="consultas-list" VBox.vgrow="ALWAYS" />
        </VBox>

        <VBox prefWidth="390.0" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-header">
                <StackPane styleClass="sidebar-icon-shell">
                    <SVGPath content="M7 3h10a2 2 0 0 1 2 2v16l-3-2-3 2-3-2-3 2V5a2 2 0 0 1 2-2zm2 5h6M9 11h6M9 14h4" styleClass="sidebar-icon" />
                </StackPane>
                <Label styleClass="sidebar-title" text="Resumo de Pagamento" />
            </HBox>

            <StackPane VBox.vgrow="ALWAYS">
                <VBox fx:id="paymentSkeleton" managed="false" spacing="18.0" styleClass="sidebar-body skeleton-container" visible="false">
                    <VBox spacing="10.0">
                        <Region prefHeight="16.0" styleClass="skeleton-line skeleton-title" />
                        <Region prefHeight="54.0" styleClass="skeleton-block" />
                    </VBox>

                    <Separator />

                    <VBox spacing="10.0">
                        <Region prefHeight="16.0" styleClass="skeleton-line skeleton-subtitle" />
                        <Region prefHeight="18.0" styleClass="skeleton-line skeleton-line-wide" />
                        <Region prefHeight="18.0" styleClass="skeleton-line skeleton-line-medium" />
                        <Region prefHeight="18.0" styleClass="skeleton-line skeleton-line-short" />
                    </VBox>

                    <VBox spacing="10.0">
                        <Region prefHeight="16.0" styleClass="skeleton-line skeleton-subtitle" />
                        <Region prefHeight="44.0" styleClass="skeleton-block" />
                    </VBox>

                    <HBox spacing="10.0">
                        <Region HBox.hgrow="ALWAYS" prefHeight="84.0" styleClass="skeleton-block" />
                        <Region HBox.hgrow="ALWAYS" prefHeight="84.0" styleClass="skeleton-block" />
                        <Region HBox.hgrow="ALWAYS" prefHeight="84.0" styleClass="skeleton-block" />
                    </HBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <Region prefHeight="54.0" styleClass="skeleton-block skeleton-button" />
                </VBox>

                <VBox fx:id="paymentDetailsContent" spacing="18.0" styleClass="sidebar-body">
                    <VBox spacing="5.0">
                        <Label styleClass="sub-section-title" text="Dados do Paciente" />

                        <VBox spacing="3.0">
                            <Label fx:id="pacienteNome" styleClass="bold-text" text="-" />
                            <Label fx:id="pacienteNif" styleClass="small-text" text="NIF: -" />
                        </VBox>
                    </VBox>

                    <Separator />

                    <VBox spacing="10.0">
                        <Label styleClass="sub-section-title" text="Procedimentos" />
                        <GridPane hgap="10.0" styleClass="procedure-table-header">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="38.0" />
                                <ColumnConstraints percentWidth="22.0" />
                                <ColumnConstraints percentWidth="14.0" />
                                <ColumnConstraints percentWidth="26.0" />
                            </columnConstraints>
                            <Label styleClass="procedure-table-heading" text="Procedimento" />
                            <Label GridPane.columnIndex="1" styleClass="procedure-table-heading" text="Tipo" />
                            <Label GridPane.columnIndex="2" styleClass="procedure-table-heading" text="IVA" />
                            <Label GridPane.columnIndex="3" styleClass="procedure-table-heading procedure-table-heading-right" text="Valor Final" />
                        </GridPane>
                        <VBox fx:id="procedimentosContainer" spacing="8.0" />

                    </VBox>

                    <VBox spacing="6.0">
                        <Label styleClass="sub-section-title" text="Seguro" />
                        <ComboBox fx:id="seguroCombo"
                                  maxWidth="Infinity"
                                  promptText="Selecionar seguro"
                                  styleClass="insurance-combo" />
                    </VBox>

                    <HBox alignment="CENTER_LEFT" styleClass="value-row">
                        <Label styleClass="total-pay-label" text="Valor Final" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="valorPagarLabel" styleClass="total-pay-value" text="&#8364; 0.00" />
                    </HBox>

                    <VBox spacing="12.0">
                        <Label styleClass="small-text" text="Metodo de Pagamento" />

                        <HBox spacing="10.0">
                            <ToggleButton fx:id="numerarioBtn"
                                          alignment="CENTER"
                                          contentDisplay="TOP"
                                          maxWidth="Infinity"
                                          mnemonicParsing="false"
                                          styleClass="payment-btn"
                                          text="Numerario"
                                          textAlignment="CENTER"
                                          wrapText="true"
                                          HBox.hgrow="ALWAYS">
                                <graphic>
                                    <StackPane styleClass="payment-icon-shell">
                                        <SVGPath content="M4 8h16v9a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V8zm0 0a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3M15.5 12.5a1.5 1.5 0 1 0 0 3a1.5 1.5 0 0 0 0-3z" styleClass="payment-icon" />
                                    </StackPane>
                                </graphic>
                            </ToggleButton>

                            <ToggleButton fx:id="multibancoBtn"
                                          alignment="CENTER"
                                          contentDisplay="TOP"
                                          maxWidth="Infinity"
                                          mnemonicParsing="false"
                                          styleClass="payment-btn"
                                          text="Cartao"
                                          textAlignment="CENTER"
                                          wrapText="true"
                                          HBox.hgrow="ALWAYS">
                                <graphic>
                                    <StackPane styleClass="payment-icon-shell">
                                        <SVGPath content="M3 7a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v10a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V7zm0 2.5h18M7 15h4" styleClass="payment-icon" />
                                    </StackPane>
                                </graphic>
                            </ToggleButton>

                            <ToggleButton fx:id="mbwayBtn"
                                          alignment="CENTER"
                                          contentDisplay="TOP"
                                          maxWidth="Infinity"
                                          mnemonicParsing="false"
                                          styleClass="payment-btn"
                                          text="MB WAY"
                                          textAlignment="CENTER"
                                          wrapText="true"
                                          HBox.hgrow="ALWAYS">
                                <graphic>
                                    <StackPane styleClass="payment-icon-shell">
                                        <SVGPath content="M9 3.5h6A2.5 2.5 0 0 1 17.5 6v12A2.5 2.5 0 0 1 15 20.5H9A2.5 2.5 0 0 1 6.5 18V6A2.5 2.5 0 0 1 9 3.5zm1 2.5h4M12 17h.01" styleClass="payment-icon" />
                                    </StackPane>
                                </graphic>
                            </ToggleButton>
                        </HBox>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <Button fx:id="emitirReciboBtn"
                            maxWidth="Infinity"
                            mnemonicParsing="false"
                            onAction="#emitirRecibo"
                            styleClass="main-action-button"
                            text="EMITIR FATURA - RECIBO" />
                </VBox>
            </StackPane>
        </VBox>
    </HBox>
</VBox>

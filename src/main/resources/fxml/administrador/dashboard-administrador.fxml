<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefHeight="768.0" prefWidth="1366.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.administrador.DashboardAdministradorController"
      stylesheets="@../../css/assistente-style.css"
      styleClass="root">

    <!-- Navbar Horizontal -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header">
        <padding><Insets top="12.0" right="24.0" bottom="12.0" left="24.0" /></padding>
        <StackPane styleClass="logo-shell">
            <ImageView fitHeight="42.0" pickOnBounds="true" preserveRatio="true" styleClass="logo-image">
                <image><Image url="@../../images/logo.png" /></image>
            </ImageView>
        </StackPane>
        <HBox alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS">
            <Button onAction="#abrirDashboard" styleClass="nav-button-active" text="Dashboard" mnemonicParsing="false" />
            <Button onAction="#abrirUtilizadores" styleClass="nav-button" text="Utilizadores" mnemonicParsing="false" />
            <Button onAction="#abrirAgendaClinica" styleClass="nav-button" text="Agenda Clínica" mnemonicParsing="false" />
            <Button onAction="#abrirProcedimentos" styleClass="nav-button" text="Procedimentos" mnemonicParsing="false" />
            <Button onAction="#abrirFinanceiro" styleClass="nav-button" text="Financeiro" mnemonicParsing="false" />
            <Button onAction="#abrirEstoque" styleClass="nav-button" text="Estoque" mnemonicParsing="false" />
            <Button onAction="#abrirAuditoria" styleClass="nav-button" text="Auditoria" mnemonicParsing="false" />
            <Button onAction="#abrirSeguros" styleClass="nav-button" text="Seguros" mnemonicParsing="false" />
        </HBox>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <VBox alignment="CENTER_RIGHT" spacing="2.0">
                <Label fx:id="lblNomeUtilizador" styleClass="user-name" text="Administrador" />
                <Label styleClass="user-role" text="Administrador" />
            </VBox>
            <Button onAction="#fazerLogout" styleClass="icon-button" mnemonicParsing="false">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M15 3h3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-3M10 17l5-5-5-5M15 12H4" styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- Conteúdo Principal -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
        <content>
            <VBox spacing="22.0" styleClass="dashboard-body">
                <padding><Insets top="24.0" right="28.0" bottom="32.0" left="28.0" /></padding>

                <!-- Título -->
                <HBox alignment="BOTTOM_LEFT" spacing="16.0">
                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblSaudacao" styleClass="greeting-title" text="Painel de Administração" />
                        <Label fx:id="lblSubtitulo" styleClass="greeting-subtitle" text="Resumo geral da clínica." />
                    </VBox>
                </HBox>

                <!-- Linha 1: Indicadores Principais -->
                <HBox spacing="14.0">
                    <VBox styleClass="stat-card-normal" spacing="6.0" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="stat-desc" text="Consultas Hoje" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label styleClass="stat-tag-blue" text="Agenda" />
                        </HBox>
                        <Label fx:id="lblConsultasHoje" styleClass="stat-number" text="0" />
                    </VBox>

                    <VBox styleClass="stat-card-normal" spacing="6.0" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="stat-desc" text="Dentistas Ativos" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label styleClass="stat-tag-normal" text="Equipa" />
                        </HBox>
                        <Label fx:id="lblDentistasAtivos" styleClass="stat-number" text="0" />
                    </VBox>

                    <VBox styleClass="stat-card-normal" spacing="6.0" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="stat-desc" text="Pacientes Registados" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label styleClass="stat-tag-blue" text="Pacientes" />
                        </HBox>
                        <Label fx:id="lblPacientesRegistados" styleClass="stat-number" text="0" />
                    </VBox>
                </HBox>

                <!-- Linha 2: Indicadores Financeiros -->
                <HBox spacing="14.0">
                    <VBox styleClass="stat-card-normal" spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-desc" text="Receitas do Mês" />
                        <Label fx:id="lblReceitasMes" styleClass="stat-number" text="€ 0,00" />
                    </VBox>

                    <VBox styleClass="stat-card-normal" spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-desc" text="Despesas do Mês" />
                        <Label fx:id="lblDespesasMes" styleClass="stat-number-warn" text="€ 0,00" />
                    </VBox>

                    <VBox styleClass="stat-card-accent" spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label-light" text="Lucro Estimado" />
                        <Label fx:id="lblLucroEstimado" styleClass="stat-value-light" text="€ 0,00" />
                    </VBox>
                </HBox>

                <!-- Linha 3: Alertas e Atalhos -->
                <HBox spacing="14.0">
                    <!-- Alertas -->
                    <VBox styleClass="section-card" spacing="12.0" HBox.hgrow="ALWAYS">
                        <HBox styleClass="panel-header-bar" alignment="CENTER_LEFT" spacing="12.0">
                            <Label styleClass="panel-section-title" text="Alertas" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblAlertasPendentes" styleClass="stat-tag-danger" text="0 pendentes" />
                        </HBox>
                        <VBox fx:id="containerAlertas" spacing="8.0" minHeight="120.0">
                            <padding><Insets top="8.0" right="4.0" bottom="8.0" left="4.0" /></padding>
                            <Label styleClass="section-caption" text="A carregar alertas..." />
                        </VBox>
                    </VBox>

                    <!-- Atalhos Rápidos -->
                    <VBox styleClass="section-card" spacing="12.0" HBox.hgrow="ALWAYS" prefWidth="320.0">
                        <HBox styleClass="panel-header-bar" alignment="CENTER_LEFT" spacing="12.0">
                            <Label styleClass="panel-section-title" text="Atalhos Rápidos" />
                            <Region HBox.hgrow="ALWAYS" />
                        </HBox>
                        <VBox spacing="10.0" minHeight="120.0">
                            <padding><Insets top="8.0" right="4.0" bottom="8.0" left="4.0" /></padding>
                            <Button onAction="#abrirUtilizadores" styleClass="primary-button" text="⚙  Gestão de Utilizadores" maxWidth="Infinity" prefHeight="44.0" />
                            <Button onAction="#abrirProcedimentos" styleClass="primary-button" text="📋  Gestão de Procedimentos" maxWidth="Infinity" prefHeight="44.0" />
                            <Button onAction="#abrirFinanceiro" styleClass="primary-button" text="💰  Relatórios Financeiros" maxWidth="Infinity" prefHeight="44.0" />
                            <Button onAction="#abrirAuditoria" styleClass="primary-button" text="📝  Auditoria do Sistema" maxWidth="Infinity" prefHeight="44.0" />
                        </VBox>
                    </VBox>
                </HBox>

                <!-- Materiais Críticos -->
                <VBox styleClass="section-card" spacing="12.0">
                    <HBox styleClass="panel-header-bar" alignment="CENTER_LEFT" spacing="12.0">
                        <Label styleClass="panel-section-title" text="Materiais Críticos" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button styleClass="secondary-button" text="Ver Estoque" onAction="#abrirEstoque" mnemonicParsing="false" />
                    </HBox>
                    <VBox fx:id="containerMateriaisCriticos" spacing="8.0" minHeight="80.0">
                        <padding><Insets top="8.0" right="4.0" bottom="8.0" left="4.0" /></padding>
                        <Label styleClass="section-caption" text="A carregar materiais..." />
                    </VBox>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>
</VBox>
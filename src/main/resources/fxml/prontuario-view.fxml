<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefHeight="768.0" prefWidth="1366.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.ProntuarioController"
      stylesheets="@../css/dashboard-style.css"
      styleClass="root">

    <!-- ═══════════════ HEADER ═══════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="28.0" styleClass="header">
        <padding>
            <Insets top="14.0" right="28.0" bottom="14.0" left="28.0" />
        </padding>

        <StackPane styleClass="logo-shell">
            <ImageView fitHeight="46.0" pickOnBounds="true" preserveRatio="true" smooth="true" styleClass="logo-image">
                <image>
                    <Image url="@../images/logo.png" />
                </image>
            </ImageView>
        </StackPane>

        <HBox alignment="CENTER_LEFT" spacing="14.0" HBox.hgrow="ALWAYS">
            <Button mnemonicParsing="false" onAction="#abrirAgenda"   styleClass="nav-button"        text="Agenda" />
            <Button mnemonicParsing="false" onAction="#abrirPacientes" styleClass="nav-button-active" text="Pacientes" />
            <Button mnemonicParsing="false" onAction="#abrirFaturacao" styleClass="nav-button"        text="Pagamentos" />
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <Button mnemonicParsing="false" styleClass="icon-button">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M15 17h5l-1.4-1.4c-.4-.4-.6-.9-.6-1.4V11c0-2.8-1.9-5.2-4.5-5.9V4.5a1.5 1.5 0 0 0-3 0v.6C7.9 5.8 6 8.2 6 11v3.2c0 .5-.2 1-.6 1.4L4 17h5m6 0a3 3 0 0 1-6 0" styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>

            <VBox alignment="CENTER_RIGHT" spacing="2.0">
                <Label fx:id="nomeUtilizador" styleClass="user-name" text="Rececionista" />
                <Label styleClass="user-role" text="Rececionista" />
            </VBox>

            <Button mnemonicParsing="false" onAction="#fazerLogout" styleClass="icon-button">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M15 3h3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-3M10 17l5-5-5-5M15 12H4" styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- ═══════════════ CORPO ═══════════════ -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="profile-scroll" VBox.vgrow="ALWAYS">
        <content>
            <VBox spacing="22.0" styleClass="dashboard-body">
                <padding>
                    <Insets top="24.0" right="28.0" bottom="28.0" left="28.0" />
                </padding>

                <!-- Título da página + botão voltar -->
                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <VBox spacing="4.0">
                        <Label styleClass="page-title" text="Prontuário Clínico" />
                        <Label styleClass="page-subtitle" text="Registo completo da saúde do paciente: historial médico, alergias, medicação e observações clínicas." />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" onAction="#voltarPacientes" styleClass="secondary-button" text="Voltar aos pacientes" />
                </HBox>

                <HBox spacing="22.0">

                    <!-- ─── Coluna esquerda: resumo do paciente ─── -->
                    <VBox prefWidth="300.0" spacing="18.0">
                        <VBox spacing="14.0" styleClass="section-card">
                            <Label styleClass="section-title" text="Paciente" />

                            <VBox spacing="4.0" styleClass="info-item">
                                <Label fx:id="lblPacienteNome" styleClass="info-meta-strong" text="-" />
                                <Label fx:id="lblPacienteMeta" styleClass="info-meta" text="NIF -" />
                            </VBox>

                            <VBox spacing="10.0">
                                <HBox alignment="CENTER_LEFT" styleClass="profile-highlight-row">
                                    <Label styleClass="profile-highlight-label" text="Criado em" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblDataCriacao" styleClass="profile-highlight-value" text="-" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" styleClass="profile-highlight-row">
                                    <Label styleClass="profile-highlight-label" text="Última atualização" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblUltimaAtualizacao" styleClass="profile-highlight-value" text="-" />
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- Aviso de edição -->
                        <VBox spacing="8.0" styleClass="section-card">
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <SVGPath content="M12 2a10 10 0 1 1 0 20A10 10 0 0 1 12 2zm0 9v5m0-8v1" styleClass="header-icon" />
                                <Label styleClass="section-title" text="Edição" />
                            </HBox>
                            <Label styleClass="section-caption" text="Clique em Editar Prontuário para alterar os dados clínicos. Confirme com Guardar para persistir as alterações." wrapText="true" />
                            <Button fx:id="btnEditar" maxWidth="Infinity" mnemonicParsing="false"
                                    onAction="#ativarEdicao" styleClass="primary-button" text="Editar Prontuário" />
                        </VBox>
                    </VBox>

                    <!-- ─── Coluna direita: formulário do prontuário ─── -->
                    <VBox spacing="18.0" HBox.hgrow="ALWAYS">

                        <!-- Cabeçalho da secção + botões -->
                        <VBox spacing="16.0" styleClass="section-card">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="4.0">
                                    <Label styleClass="section-title" text="Dados Clínicos" />
                                    <Label styleClass="section-caption" text="Informações de saúde do paciente registadas pela clínica." />
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox spacing="10.0">
                                    <Button fx:id="btnCancelar" managed="false" mnemonicParsing="false"
                                            onAction="#cancelarEdicao" styleClass="secondary-button"
                                            text="Cancelar" visible="false" />
                                    <Button fx:id="btnGuardar" managed="false" mnemonicParsing="false"
                                            onAction="#guardarEdicao" styleClass="primary-button"
                                            text="Guardar alterações" visible="false" />
                                </HBox>
                            </HBox>

                            <Separator />

                            <!-- Grid de campos -->
                            <GridPane hgap="16.0" vgap="16.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="30.0" />
                                    <ColumnConstraints percentWidth="70.0" />
                                </columnConstraints>

                                <!-- Grupo sanguíneo -->
                                <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label styleClass="profile-field-label" text="Grupo Sanguíneo" />
                                    <TextField fx:id="txtGrupoSanguineo"
                                               promptText="Ex: A+"
                                               styleClass="profile-input"
                                               maxWidth="Infinity" />
                                </VBox>

                                <!-- Alergias (ocupa coluna 1 da linha 0) -->
                                <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label styleClass="profile-field-label" text="Alergias Conhecidas" />
                                    <TextArea fx:id="txtAlergias"
                                              promptText="Descreva as alergias conhecidas…"
                                              styleClass="nova-marcacao-textarea"
                                              prefHeight="70.0" wrapText="true" />
                                </VBox>

                                <!-- Medicação em uso (linha 1, col 0-1) -->
                                <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                                    <Label styleClass="profile-field-label" text="Medicação em Uso" />
                                    <TextArea fx:id="txtMedicamentosUso"
                                              promptText="Liste a medicação atual do paciente…"
                                              styleClass="nova-marcacao-textarea"
                                              prefHeight="80.0" wrapText="true" />
                                </VBox>

                                <!-- Historial médico (linha 2, col 0-1) -->
                                <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                                    <Label styleClass="profile-field-label" text="Historial Médico Geral" />
                                    <TextArea fx:id="txtHistoricoMedico"
                                              promptText="Doenças crónicas, cirurgias anteriores, internamentos…"
                                              styleClass="nova-marcacao-textarea"
                                              prefHeight="90.0" wrapText="true" />
                                </VBox>

                                <!-- Historial odontológico (linha 3, col 0-1) -->
                                <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2">
                                    <Label styleClass="profile-field-label" text="Historial Odontológico" />
                                    <TextArea fx:id="txtHistoricoOdontologico"
                                              promptText="Tratamentos dentários anteriores, próteses, implantes…"
                                              styleClass="nova-marcacao-textarea"
                                              prefHeight="90.0" wrapText="true" />
                                </VBox>

                                <!-- Observações clínicas (linha 4, col 0-1) -->
                                <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2">
                                    <Label styleClass="profile-field-label" text="Observações Clínicas" />
                                    <TextArea fx:id="txtObservacoesClinicas"
                                              promptText="Notas e observações do clínico…"
                                              styleClass="nova-marcacao-textarea"
                                              prefHeight="80.0" wrapText="true" />
                                </VBox>

                                <!-- Observações gerais (linha 5, col 0-1) -->
                                <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2">
                                    <Label styleClass="profile-field-label" text="Observações Gerais" />
                                    <TextArea fx:id="txtObservacoes"
                                              promptText="Outras informações relevantes…"
                                              styleClass="nova-marcacao-textarea"
                                              prefHeight="70.0" wrapText="true" />
                                </VBox>
                            </GridPane>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </content>
    </ScrollPane>
</VBox>

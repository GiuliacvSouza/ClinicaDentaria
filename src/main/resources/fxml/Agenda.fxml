<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768" prefWidth="1400" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <!-- Header -->
        <HBox prefHeight="80" style="-fx-padding: 15 30; -fx-spacing: 50; -fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
            <!-- Left Section -->
            <HBox style="-fx-spacing: 30;">
                <!-- Logo -->
                <VBox style="-fx-background-color: #4b928e; -fx-padding: 8; -fx-border-radius: 8; -fx-spacing: 0; -fx-alignment: center; -fx-pref-width: 70;">
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11;" text="Clínica" />
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11;" text="Dentária" />
                </VBox>
                <!-- Navigation -->
                <HBox style="-fx-spacing: 30; -fx-alignment: center;">
                    <Button style="-fx-background-color: #78a5a1; -fx-text-fill: white; -fx-padding: 8 20; -fx-font-weight: bold; -fx-font-size: 12;" text="Agenda" />
                    <Button style="-fx-cursor: hand; -fx-background-color: transparent; -fx-font-size: 12;" text="Pacientes" />
                    <Button style="-fx-cursor: hand; -fx-background-color: transparent; -fx-font-size: 12;" text="Faturação" />
                </HBox>
            </HBox>
            <!-- Right Side -->
            <Region HBox.hgrow="ALWAYS" />
            <HBox style="-fx-spacing: 20; -fx-alignment: center;">
                <!-- Search -->
                <TextField prefWidth="250" promptText="Nome, NIF ou telemóvel" style="-fx-padding: 8 15; -fx-font-size: 11;" />
                <!-- Notification Button -->
                <Button style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;" />
                <!-- User Info -->
                <VBox style="-fx-spacing: 3;">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 11;" text="Joana Silva" />
                    <Label alignment="CENTER" style="-fx-font-size: 9; -fx-text-fill: gray;" text="Rececionista" textAlignment="CENTER" />
                </VBox>
                <!-- Logout Button -->
                <Button style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;" />
            </HBox>
        </HBox>
    </top>

    <center>
        <HBox prefHeight="700" prefWidth="1400">
            <!-- Main Content -->
            <VBox style="-fx-padding: 20; -fx-spacing: 20; -fx-background-color: #f3f7f8;" HBox.hgrow="ALWAYS">

                <!-- Controls Row -->
                <HBox style="-fx-spacing: 15; -fx-alignment: center-left; -fx-pref-height: 50;">
                    <!-- Date Navigation -->
                    <HBox style="-fx-spacing: 0; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 8; -fx-padding: 5; -fx-background-color: white;">
                        <Button style="-fx-padding: 8 15; -fx-background-color: transparent; -fx-font-size: 14;" text="‹" />
                        <Label style="-fx-padding: 8 20; -fx-font-weight: bold; -fx-font-size: 11;" text="Seg, 23 de março, 2026" />
                        <Button style="-fx-padding: 8 15; -fx-background-color: transparent; -fx-font-size: 14;" text="›" />
                    </HBox>

                    <Button style="-fx-padding: 8 15; -fx-background-color: #d1d5db; -fx-font-size: 11;" text="Hoje" />

                    <ComboBox prefWidth="150" promptText="Todos os dentistas" style="-fx-padding: 8; -fx-font-size: 11;" />

                    <Region HBox.hgrow="ALWAYS" />

                    <!-- Filter Buttons -->
                    <HBox style="-fx-spacing: 0; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 8; -fx-padding: 0; -fx-background-color: white;">
                        <Button style="-fx-background-color: #78a5a1; -fx-text-fill: white; -fx-padding: 8 15; -fx-font-size: 10; -fx-font-weight: bold;" text="Todas" />
                        <Button style="-fx-padding: 8 15; -fx-font-size: 10; -fx-background-color: white;" text="Pendentes" />
                        <Button style="-fx-padding: 8 15; -fx-font-size: 10; -fx-background-color: white;" text="Em espera" />
                        <Button style="-fx-padding: 8 15; -fx-font-size: 10; -fx-background-color: white;" text="Em consulta" />
                        <Button style="-fx-padding: 8 15; -fx-font-size: 10; -fx-background-color: white;" text="Concluídas" />
                    </HBox>
                </HBox>

                <!-- Schedule Table -->
                <TableView prefHeight="500" style="-fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-color: white;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="80" text="Hora" />
                        <TableColumn prefWidth="183.2000274658203" text="Paciente" />
                        <TableColumn prefWidth="159.20001220703125" text="Dentista" />
                        <TableColumn prefWidth="261.5999755859375" text="Procedimento" />
                        <TableColumn prefWidth="178.4000244140625" text="Estado" />
                        <TableColumn prefWidth="197.60003662109375" text="Ações" />
                    </columns>
                    <placeholder>
                        <Label text="Nenhum agendamento encontrado" />
                    </placeholder>
                </TableView>
            </VBox>

            <!-- Right Sidebar -->
            <VBox prefWidth="300" style="-fx-padding: 20; -fx-spacing: 20; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 0 1; -fx-background-color: white;">
                <!-- New Appointment Button -->
                <Button prefHeight="60" prefWidth="Infinity" style="-fx-background-color: #a0d8e4; -fx-text-fill: #1a3a4a; -fx-padding: 20; -fx-font-weight: bold; -fx-font-size: 13; -fx-cursor: hand;" text="+ NOVA MARCAÇÃO" />

                <!-- Waiting List -->
                <VBox style="-fx-spacing: 15;" VBox.vgrow="ALWAYS">
                    <HBox style="-fx-spacing: 10; -fx-alignment: center-left;">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 12;" text="LISTA DE ESPERA" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button style="-fx-background-color: #ff3b30; -fx-text-fill: white; -fx-padding: 5 10; -fx-font-size: 10; -fx-font-weight: bold;" text="Adicionar" />
                    </HBox>

                    <!-- Waiting Cards -->
                    <ScrollPane fitToWidth="true" style="-fx-border-color: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                        <VBox style="-fx-spacing: 12; -fx-background-color: transparent;">
                            <!-- Card 1 -->
                            <HBox style="-fx-background-color: #f9fafb; -fx-padding: 15; -fx-border-radius: 12; -fx-border-color: transparent; -fx-spacing: 10;">
                                <VBox style="-fx-spacing: 5;" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 11;" text="Fernando Mota" />
                                    <Label style="-fx-font-size: 10; -fx-text-fill: gray;" text="Implante" />
                                </VBox>
                                <Button style="-fx-background-color: #589691; -fx-text-fill: white; -fx-padding: 8; -fx-font-size: 10; -fx-font-weight: bold;" text="Encaixar" />
                            </HBox>
                            <!-- Card 2 -->
                            <HBox style="-fx-background-color: #f9fafb; -fx-padding: 15; -fx-border-radius: 12; -fx-border-color: transparent; -fx-spacing: 10;">
                                <VBox style="-fx-spacing: 5;" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 11;" text="Sofia Castro" />
                                    <Label style="-fx-font-size: 10; -fx-text-fill: gray;" text="Obturação" />
                                </VBox>
                                <Button style="-fx-background-color: #589691; -fx-text-fill: white; -fx-padding: 8; -fx-font-size: 10; -fx-font-weight: bold;" text="Encaixar" />
                            </HBox>
                            <!-- Card 3 -->
                            <HBox style="-fx-background-color: #f9fafb; -fx-padding: 15; -fx-border-radius: 12; -fx-border-color: transparent; -fx-spacing: 10;">
                                <VBox style="-fx-spacing: 5;" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 11;" text="Anabela Junior" />
                                    <Label style="-fx-font-size: 10; -fx-text-fill: gray;" text="Extração" />
                                </VBox>
                                <Button style="-fx-background-color: #589691; -fx-text-fill: white; -fx-padding: 8; -fx-font-size: 10; -fx-font-weight: bold;" text="Encaixar" />
                            </HBox>
                            <!-- Card 4 -->
                            <HBox style="-fx-background-color: #f9fafb; -fx-padding: 15; -fx-border-radius: 12; -fx-border-color: transparent; -fx-spacing: 10;">
                                <VBox style="-fx-spacing: 5;" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 11;" text="Ana Maria" />
                                    <Label style="-fx-font-size: 10; -fx-text-fill: gray;" text="Extração" />
                                </VBox>
                                <Button style="-fx-background-color: #589691; -fx-text-fill: white; -fx-padding: 8; -fx-font-size: 10; -fx-font-weight: bold;" text="Encaixar" />
                            </HBox>
                        </VBox>
                    </ScrollPane>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>

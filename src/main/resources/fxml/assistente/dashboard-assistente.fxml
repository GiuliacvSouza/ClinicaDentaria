<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefHeight="768.0" prefWidth="1366.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.assistente.AssistenteDashboardController"
      stylesheets="@../../css/assistente-style.css"
      styleClass="root">

    <!-- ═══ NAVBAR HORIZONTAL (igual às outras páginas) ═══ -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header">
        <padding><Insets top="12.0" right="24.0" bottom="12.0" left="24.0" /></padding>

        <StackPane styleClass="logo-shell">
            <ImageView fitHeight="42.0" pickOnBounds="true" preserveRatio="true" styleClass="logo-image">
                <image><Image url="@../../images/logo.png" /></image>
            </ImageView>
        </StackPane>

        <!-- Itens de navegação — Dashboard ativo -->
        <HBox alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS">
            <Button onAction="#abrirDashboard"     styleClass="nav-button-active" text="Dashboard"           mnemonicParsing="false" />
            <Button onAction="#abrirConsultasDia"  styleClass="nav-button"        text="Consultas"           mnemonicParsing="false" />
            <Button onAction="#abrirMateriais"     styleClass="nav-button"        text="Materiais"           mnemonicParsing="false" />
            <Button onAction="#abrirMovimentacoes" styleClass="nav-button"        text="Movimentações"       mnemonicParsing="false" />
            <Button onAction="#abrirPedidosCompra" styleClass="nav-button"        text="Pedidos"             mnemonicParsing="false" />
            <Button onAction="#abrirFornecedores"  styleClass="nav-button"        text="Fornecedores"        mnemonicParsing="false" />
            <Button onAction="#abrirAlertas"       styleClass="nav-button"        text="Alertas"             mnemonicParsing="false" />
        </HBox>

        <!-- Utilizador + perfil + logout -->
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <VBox alignment="CENTER_RIGHT" spacing="2.0">
                <Label fx:id="lblNomeUtilizador" styleClass="user-name" text="Assistente" />
                <Label styleClass="user-role" text="Assistente de Consultório" />
            </VBox>
            <Button onAction="#abrirPerfil" styleClass="icon-button" mnemonicParsing="false">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"
                                 styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>
            <Button onAction="#fazerLogout" styleClass="icon-button" mnemonicParsing="false">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M15 3h3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-3M10 17l5-5-5-5M15 12H4"
                                 styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- ═══ CONTEÚDO PRINCIPAL ═══ -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
        <content>
            <VBox spacing="22.0" styleClass="dashboard-body">
                <padding><Insets top="24.0" right="28.0" bottom="32.0" left="28.0" /></padding>

                <!-- ── Saudação + botões de ação ── -->
                <HBox alignment="BOTTOM_LEFT" spacing="16.0">
                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblSaudacao"  styleClass="greeting-title"    text="Bom dia, Sofia" />
                        <Label fx:id="lblSubtitulo" styleClass="greeting-subtitle" text="Aqui está o resumo da sua atividade para hoje." />
                    </VBox>
                    <HBox spacing="10.0" alignment="BOTTOM_RIGHT">
                        <Button styleClass="primary-button"   text="Registar Movimentação"
                                onAction="#registarMovimentacao" mnemonicParsing="false" />
                        <Button styleClass="secondary-button" text="Criar Pedido de Compra"
                                onAction="#criarPedidoCompra"    mnemonicParsing="false" />
                    </HBox>
                </HBox>

                <!-- ── Cards de resumo (4 colunas iguais) ── -->
                <HBox spacing="14.0">

                    <!-- Consultas Agendadas -->
                    <VBox styleClass="stat-card-normal" spacing="6.0" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="stat-desc" text="Consultas Agendadas" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label styleClass="stat-tag-normal" text="Hoje" />
                        </HBox>
                        <Label fx:id="lblConsultasAgendadas" styleClass="stat-number" text="12" />
                    </VBox>

                    <!-- Materiais em Stock Crítico -->
                    <VBox styleClass="stat-card-danger" spacing="6.0" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="stat-desc-danger" text="Materiais em Stock Crítico" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label styleClass="stat-tag-danger" text="ALERTA" />
                        </HBox>
                        <Label fx:id="lblStockCritico" styleClass="stat-number-danger" text="04" />
                    </VBox>

                    <!-- Pedidos de Compra -->
                    <VBox styleClass="stat-card-normal" spacing="6.0" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="stat-desc" text="Pedidos de Compra" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label styleClass="stat-tag-warn" text="Pendentes" />
                        </HBox>
                        <Label fx:id="lblPedidosPendentes" styleClass="stat-number-warn" text="07" />
                    </VBox>

                    <!-- Movimentações de Stock -->
                    <VBox styleClass="stat-card-normal" spacing="6.0" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="stat-desc" text="Movimentações de Stock" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label styleClass="stat-tag-blue" text="Últimas 24h" />
                        </HBox>
                        <Label fx:id="lblMovimentacoes24h" styleClass="stat-number-blue" text="28" />
                    </VBox>
                </HBox>

                <!-- ── Fila central: Alertas Urgentes + Movimentações Recentes ── -->
                <HBox spacing="14.0">

                    <!-- ALERTAS URGENTES -->
                    <VBox styleClass="section-card" spacing="0.0" HBox.hgrow="ALWAYS">
                        <!-- cabeçalho do painel -->
                        <HBox styleClass="panel-header-bar" alignment="CENTER_LEFT" spacing="12.0">
                            <Label styleClass="panel-section-title" text="Alertas Urgentes" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button styleClass="panel-link-btn" text="Ver todos"
                                    onAction="#abrirAlertas" mnemonicParsing="false" />
                        </HBox>

                        <VBox fx:id="containerAlertas" spacing="0.0">
                            <padding><Insets top="10.0" right="4.0" bottom="10.0" left="4.0" /></padding>
                            <Label styleClass="section-caption" text="A carregar alertas..." />
                        </VBox>
                    </VBox>

                    <!-- MOVIMENTAÇÕES RECENTES -->
                    <VBox styleClass="section-card" spacing="0.0" HBox.hgrow="ALWAYS">
                        <HBox styleClass="panel-header-bar" alignment="CENTER_LEFT">
                            <Label styleClass="panel-section-title" text="Movimentações Recentes" />
                        </HBox>

                        <VBox fx:id="containerMovimentacoes" spacing="0.0">
                            <padding><Insets top="10.0" right="4.0" bottom="10.0" left="4.0" /></padding>
                            <Label styleClass="section-caption" text="A carregar movimentações..." />
                        </VBox>
                    </VBox>
                </HBox>

                <!-- ── Tabela: Próximas Consultas do Dia ── -->
                <VBox styleClass="section-card" spacing="0.0">

                    <!-- cabeçalho do painel -->
                    <HBox styleClass="panel-header-bar" alignment="CENTER_LEFT" spacing="12.0">
                        <Label styleClass="panel-section-title" text="Próximas Consultas do Dia" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button styleClass="secondary-button" text="Ver agenda completa"
                                onAction="#abrirConsultasDia" mnemonicParsing="false" />
                    </HBox>

                    <!-- Grelha de consultas com colunas alinhadas -->
                    <VBox fx:id="containerConsultasGrid"
                          VBox.vgrow="ALWAYS"
                          styleClass="consultas-grid" />

                    <!-- Rodapé -->
                    <HBox styleClass="table-footer" alignment="CENTER" spacing="4.0">
                        <Label styleClass="table-footer-label"     text="Restam " />
                        <Label fx:id="lblRestamConsultas" styleClass="table-footer-highlight" text="8 consultas" />
                        <Label styleClass="table-footer-label"     text=" para concluir o dia." />
                    </HBox>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

</VBox>

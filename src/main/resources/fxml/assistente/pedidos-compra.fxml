<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefHeight="768.0" prefWidth="1366.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.assistente.PedidosCompraController"
      stylesheets="@../../css/assistente-style.css"
      styleClass="root">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header">
        <padding><Insets top="12.0" right="24.0" bottom="12.0" left="24.0" /></padding>
        <StackPane styleClass="logo-shell">
            <ImageView fitHeight="42.0" pickOnBounds="true" preserveRatio="true" styleClass="logo-image">
                <image><Image url="@../../images/logo.png" /></image>
            </ImageView>
        </StackPane>
        <HBox alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS">
            <Button onAction="#abrirDashboard"      styleClass="nav-button"        text="Dashboard"    mnemonicParsing="false" />
            <Button onAction="#abrirConsultasDia"   styleClass="nav-button"        text="Consultas"    mnemonicParsing="false" />
            <Button onAction="#abrirMateriais"      styleClass="nav-button"        text="Materiais"    mnemonicParsing="false" />
            <Button onAction="#abrirMovimentacoes"  styleClass="nav-button"        text="Movimentações" mnemonicParsing="false" />
            <Button onAction="#abrirPedidosCompra"  styleClass="nav-button-active" text="Pedidos"      mnemonicParsing="false" />
            <Button onAction="#abrirFornecedores"   styleClass="nav-button"        text="Fornecedores" mnemonicParsing="false" />
            <Button onAction="#abrirAlertas"        styleClass="nav-button"        text="Alertas"      mnemonicParsing="false" />
        </HBox>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <VBox alignment="CENTER_RIGHT" spacing="2.0">
                <Label fx:id="lblNomeUtilizador" styleClass="user-name" text="Assistente" />
                <Label styleClass="user-role" text="Assistente de Consultório" />
            </VBox>
            <Button onAction="#abrirPerfil" styleClass="icon-button" mnemonicParsing="false">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>
            <Button onAction="#fazerLogout" styleClass="icon-button" mnemonicParsing="false">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M15 3h3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-3M10 17l5-5-5-5M15 12H4" styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- CONTEÚDO -->
    <VBox spacing="18.0" styleClass="dashboard-body" VBox.vgrow="ALWAYS">
        <padding><Insets top="24.0" right="28.0" bottom="24.0" left="28.0" /></padding>

        <HBox alignment="CENTER_LEFT" spacing="14.0">
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                <Label styleClass="page-title" text="Pedidos de Compra" />
                <Label styleClass="page-subtitle" text="Gira os pedidos de reposição de materiais junto dos fornecedores." />
            </VBox>
            <Button onAction="#criarNovoPedido" styleClass="primary-button"
                    text="+ Novo Pedido" mnemonicParsing="false" />
        </HBox>

        <HBox spacing="12.0">
            <TextField fx:id="txtPesquisa" promptText="Pesquisar por fornecedor ou material"
                       styleClass="search-field" HBox.hgrow="ALWAYS" />
        </HBox>

        <HBox spacing="10.0">
            <Button fx:id="btnTodos"     onAction="#filtrarTodos"     styleClass="filter-chip" text="Todos"     mnemonicParsing="false" />
            <Button fx:id="btnPendente"  onAction="#filtrarPendente"  styleClass="filter-chip" text="Pendente"  mnemonicParsing="false" />
            <Button fx:id="btnEnviado"   onAction="#filtrarEnviado"   styleClass="filter-chip" text="Enviado"   mnemonicParsing="false" />
            <Button fx:id="btnRecebido"  onAction="#filtrarRecebido"  styleClass="filter-chip" text="Recebido"  mnemonicParsing="false" />
            <Button fx:id="btnCancelado" onAction="#filtrarCancelado" styleClass="filter-chip" text="Cancelado" mnemonicParsing="false" />
        </HBox>

        <VBox spacing="12.0" styleClass="section-card" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="section-title" text="Lista de Pedidos" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTotalPedidos" styleClass="section-caption" text="0 pedidos" />
            </HBox>

            <TableView fx:id="tblPedidos" styleClass="dashboard-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNumero"     prefWidth="70.0"  text="Nº"
                                 styleClass="col-center" />
                    <TableColumn fx:id="colFornecedor" prefWidth="210.0" text="Fornecedor" />
                    <TableColumn fx:id="colDataPedido" prefWidth="110.0" text="Data"
                                 styleClass="col-center" />
                    <TableColumn fx:id="colAssistente" prefWidth="160.0" text="Responsável" />
                    <TableColumn fx:id="colEstado"     prefWidth="120.0" text="Estado"
                                 styleClass="col-center" />
                    <TableColumn fx:id="colTotalItens" prefWidth="70.0"  text="Itens"
                                 styleClass="col-center" />
                    <TableColumn fx:id="colValorTotal" prefWidth="110.0" text="Total"
                                 styleClass="col-right" />
                    <TableColumn fx:id="colAcoes"      prefWidth="230.0" text="Ações" />
                </columns>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 48 0;">
                        <Label text="Nenhum pedido encontrado." styleClass="empty-table-title" />
                        <Label text="Crie um novo pedido de compra para começar." styleClass="empty-table-subtitle" />
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>
    </VBox>
</VBox>

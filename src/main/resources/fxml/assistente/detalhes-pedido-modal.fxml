<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.assistente.DetalhesPedidoController"
      stylesheets="@../../css/assistente-style.css"
      styleClass="dialog-root"
      prefWidth="900.0"
      prefHeight="650.0">

    <VBox styleClass="dialog-card" VBox.vgrow="ALWAYS" spacing="0">

        <!-- Header fixo -->
        <VBox spacing="2.0" styleClass="dialog-header">
            <padding><Insets top="28.0" right="32.0" bottom="0.0" left="32.0"/></padding>
            <Label fx:id="lblTituloJanela" text="Pedido #0" styleClass="dialog-title"/>
            <Label text="Detalhes do Pedido de Compra" styleClass="dialog-subtitle"/>
        </VBox>

        <!-- Conteúdo principal (sem ScrollPane exterior — cabe na janela) -->
        <VBox spacing="20.0" styleClass="dialog-content" VBox.vgrow="ALWAYS">
            <padding><Insets top="20.0" right="32.0" bottom="0.0" left="32.0"/></padding>

            <!-- Card de informações do pedido -->
            <VBox spacing="14.0" styleClass="dialog-card-info">
                <GridPane hgap="28.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50.0"/>
                        <ColumnConstraints percentWidth="50.0"/>
                    </columnConstraints>

                    <VBox spacing="2.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Nº do pedido" styleClass="detail-field-label"/>
                        <Label fx:id="lblNumero" text="-" styleClass="detail-field-value"/>
                    </VBox>

                    <VBox spacing="2.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Estado" styleClass="detail-field-label"/>
                        <Label fx:id="lblEstado" text="-" styleClass="detail-field-value"/>
                    </VBox>

                    <VBox spacing="2.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="Fornecedor" styleClass="detail-field-label"/>
                        <Label fx:id="lblFornecedor" text="-" styleClass="detail-field-value"/>
                    </VBox>

                    <VBox spacing="2.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="Data" styleClass="detail-field-label"/>
                        <Label fx:id="lblData" text="-" styleClass="detail-field-value"/>
                    </VBox>

                    <VBox spacing="2.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="Responsável" styleClass="detail-field-label"/>
                        <Label fx:id="lblResponsavel" text="-" styleClass="detail-field-value"/>
                    </VBox>

                    <VBox spacing="2.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label text="Observações" styleClass="detail-field-label"/>
                        <Label fx:id="lblObservacoes" text="—" styleClass="detail-field-value" wrapText="true"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Secção de Itens -->
            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                <Label text="Itens do Pedido" styleClass="detail-section-label"/>

                <TableView fx:id="tblItens" styleClass="clean-table" VBox.vgrow="ALWAYS"
                           minHeight="100.0">
                    <columns>
                        <TableColumn fx:id="colMaterial"    prefWidth="340.0" text="Material" />
                        <TableColumn fx:id="colQuantidade"  prefWidth="120.0" text="Quantidade"
                                     styleClass="col-center" />
                        <TableColumn fx:id="colValorUnit"   prefWidth="130.0" text="Valor unit."
                                     styleClass="col-right" />
                        <TableColumn fx:id="colSubtotal"    prefWidth="130.0" text="Subtotal"
                                     styleClass="col-right" />
                    </columns>
                    <placeholder>
                        <Label text="Nenhum item encontrado." styleClass="empty-table-title" />
                    </placeholder>
                </TableView>
            </VBox>

            <Separator styleClass="dialog-separator"/>

            <!-- Total -->
            <HBox alignment="CENTER_RIGHT" spacing="8.0">
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Total do pedido:" styleClass="detail-total-label"/>
                <Label fx:id="lblTotal" text="0,00 €" styleClass="detail-total-value"/>
            </HBox>

        </VBox>

        <!-- Footer fixo com botão Fechar -->
        <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="dialog-footer">
            <padding><Insets top="16.0" right="32.0" bottom="24.0" left="32.0"/></padding>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#fechar" styleClass="primary-button"
                    text="Fechar" mnemonicParsing="false" prefWidth="140.0" prefHeight="46.0"/>
        </HBox>
    </VBox>
</VBox>

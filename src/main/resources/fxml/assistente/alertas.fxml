<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefHeight="768.0" prefWidth="1366.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.assistente.AlertasController"
      stylesheets="@../../css/assistente-style.css"
      styleClass="root">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header">
        <padding><Insets top="12.0" right="24.0" bottom="12.0" left="24.0" /></padding>
        <StackPane styleClass="logo-shell">
            <ImageView fitHeight="42.0" pickOnBounds="true" preserveRatio="true" styleClass="logo-image">
                <image><Image url="@../../images/logo.png" /></image>
            </ImageView>
        </StackPane>
        <HBox alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS">
            <Button onAction="#abrirDashboard"      styleClass="nav-button"        text="Dashboard"    mnemonicParsing="false" />
            <Button onAction="#abrirConsultasDia"   styleClass="nav-button"        text="Consultas"    mnemonicParsing="false" />
            <Button onAction="#abrirMateriais"      styleClass="nav-button"        text="Materiais"    mnemonicParsing="false" />
            <Button onAction="#abrirMovimentacoes"  styleClass="nav-button"        text="Movimentacoes" mnemonicParsing="false" />
            <Button onAction="#abrirPedidosCompra"  styleClass="nav-button"        text="Pedidos"      mnemonicParsing="false" />
            <Button onAction="#abrirFornecedores"   styleClass="nav-button"        text="Fornecedores" mnemonicParsing="false" />
            <Button onAction="#abrirAlertas"        styleClass="nav-button-active" text="Alertas"      mnemonicParsing="false" />
        </HBox>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <VBox alignment="CENTER_RIGHT" spacing="2.0">
                <Label fx:id="lblNomeUtilizador" styleClass="user-name" text="Assistente" />
                <Label styleClass="user-role" text="Assistente de Consultorio" />
            </VBox>
            <Button onAction="#fazerLogout" styleClass="icon-button" mnemonicParsing="false">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M15 3h3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-3M10 17l5-5-5-5M15 12H4" styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- CONTEÚDO -->
    <VBox spacing="18.0" styleClass="dashboard-body" VBox.vgrow="ALWAYS">
        <padding><Insets top="24.0" right="28.0" bottom="24.0" left="28.0" /></padding>

        <HBox alignment="CENTER_LEFT" spacing="14.0">
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                <Label styleClass="page-title" text="Alertas de Stock" />
                <Label styleClass="page-subtitle" text="Materiais com quantidade abaixo do nivel minimo configurado." />
            </VBox>
            <Button onAction="#abrirPedidosCompra" styleClass="primary-button"
                    text="Criar Pedido de Compra" mnemonicParsing="false" />
        </HBox>

        <!-- Stats de resumo -->
        <HBox spacing="16.0">
            <VBox spacing="6.0" styleClass="stat-card-accent" HBox.hgrow="ALWAYS">
                <Label styleClass="stat-label-light" text="Total de alertas" />
                <Label fx:id="lblTotalAlertas" styleClass="stat-value-light" text="0" />
            </VBox>
            <VBox spacing="6.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label styleClass="stat-label" text="Stock baixo" />
                <Label fx:id="lblStockBaixo" styleClass="stat-value" text="0" />
            </VBox>
            <VBox spacing="6.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label styleClass="stat-label" text="Stock critico (zerado)" />
                <Label fx:id="lblStockCritico" styleClass="stat-value" text="0" />
            </VBox>
        </HBox>

        <!-- Filtros -->
        <HBox spacing="10.0">
            <Button fx:id="btnTodos"   onAction="#filtrarTodos"   styleClass="filter-chip" text="Todos"   mnemonicParsing="false" />
            <Button fx:id="btnBaixo"   onAction="#filtrarBaixo"   styleClass="filter-chip" text="Baixo"   mnemonicParsing="false" />
            <Button fx:id="btnCritico" onAction="#filtrarCritico" styleClass="filter-chip" text="Critico" mnemonicParsing="false" />
        </HBox>

        <!-- Lista de alertas (cards dinâmicos) -->
        <VBox spacing="12.0" styleClass="section-card" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="section-title" text="Materiais em Alerta" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#atualizarAlertas" styleClass="secondary-button"
                        text="Atualizar" mnemonicParsing="false" />
            </HBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="containerAlertas" spacing="10.0">
                        <Label styleClass="section-caption" text="A carregar alertas..." />
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </VBox>
</VBox>

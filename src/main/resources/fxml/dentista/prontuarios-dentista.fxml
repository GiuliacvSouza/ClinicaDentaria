<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefHeight="768.0" prefWidth="1366.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.dentista.ProntuariosDentistaController"
      stylesheets="@../../css/assistente-style.css"
      styleClass="root">

    <!-- Navbar Horizontal -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header">
        <padding><Insets top="12.0" right="24.0" bottom="12.0" left="24.0" /></padding>

        <StackPane styleClass="logo-shell">
            <ImageView fitHeight="42.0" pickOnBounds="true" preserveRatio="true" styleClass="logo-image">
                <image><Image url="@../../images/logo.png" /></image>
            </ImageView>
        </StackPane>

        <HBox alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS">
            <Button onAction="#abrirDashboard" styleClass="nav-button" text="Dashboard" mnemonicParsing="false" />
            <Button onAction="#abrirAgenda" styleClass="nav-button" text="Agenda" mnemonicParsing="false" />
            <Button onAction="#abrirProntuarios" styleClass="nav-button-active" text="Prontuários" mnemonicParsing="false" />
            <Button onAction="#abrirPrescricoes" styleClass="nav-button" text="Prescrições" mnemonicParsing="false" />
            <Button onAction="#abrirPlanosTratamento" styleClass="nav-button" text="Planos de Tratamento" mnemonicParsing="false" />
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <VBox alignment="CENTER_RIGHT" spacing="2.0">
                <Label fx:id="lblNomeUtilizador" styleClass="user-name" text="Dr. Dentista" />
                <Label styleClass="user-role" text="Médico Dentista" />
            </VBox>
            <Button onAction="#abrirPerfil" styleClass="icon-button" mnemonicParsing="false">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>
            <Button onAction="#fazerLogout" styleClass="icon-button" mnemonicParsing="false">
                <graphic>
                    <StackPane styleClass="icon-shell">
                        <SVGPath content="M15 3h3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-3M10 17l5-5-5-5M15 12H4" styleClass="header-icon" />
                    </StackPane>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- Conteúdo Principal -->
    <HBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-padding: 10;">

        <!-- ═══ Painel Esquerdo: Lista de Pacientes ═══ -->
        <VBox spacing="14.0" prefWidth="330.0" minWidth="280.0" maxWidth="360.0"
              styleClass="section-card">
            <padding><Insets top="14.0" right="14.0" bottom="14.0" left="14.0" /></padding>

            <Label styleClass="section-title" text="Pacientes" />
            <TextField fx:id="txtPesquisa"
                       promptText="Pesquisar por nome, NIF ou contacto..."
                       styleClass="search-field" />
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label text="Filtrar por:" styleClass="section-caption" style="-fx-font-size: 12px;" />
                <ComboBox fx:id="cmbFiltro"
                          prefWidth="180.0"
                          styleClass="form-combo" />
            </HBox>

            <!-- ListView de pacientes ocupa todo o espaço vertical restante do painel esquerdo -->
            <ListView fx:id="lstPacientes"
                      VBox.vgrow="ALWAYS"
                      styleClass="patients-list">
                <placeholder>
                    <Label text="Nenhum paciente encontrado." styleClass="empty-table-subtitle" />
                </placeholder>
            </ListView>
        </VBox>

        <!-- ═══ Painel Direito: ScrollPane com prontuário ═══ -->
        <ScrollPane fx:id="scrollProntuario"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #ffffff; -fx-background: #ffffff; -fx-border-color: #dce7e4; -fx-border-radius: 18; -fx-background-radius: 18;">

            <!-- StackPane permite sobrepor placeholder e prontuário -->
            <StackPane>
                <padding><Insets top="14.0" right="14.0" bottom="20.0" left="14.0" /></padding>

                <!-- Placeholder: nenhum paciente selecionado -->
                <VBox fx:id="panePlaceholder" alignment="CENTER" spacing="10.0" minHeight="400.0">
                    <Label text="Selecione um paciente para visualizar o prontuário."
                           styleClass="section-caption"
                           style="-fx-font-size: 14px;"
                           wrapText="true" />
                </VBox>

                <!-- Conteúdo do Prontuário -->
                <VBox fx:id="paneProntuario" spacing="16.0" visible="false">

                    <!-- Cabeçalho do Paciente -->
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <StackPane prefWidth="48.0" prefHeight="48.0"
                                   style="-fx-background-color: #0066cc; -fx-background-radius: 24;">
                            <Label fx:id="lblIniciais" text="PA"
                                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" />
                        </StackPane>
                        <VBox spacing="2.0">
                            <Label fx:id="lblNomePaciente" text="Paciente"
                                   styleClass="section-title"
                                   style="-fx-font-size: 18px;" />
                            <Label fx:id="lblMetaPaciente"
                                   text="NIF: 000000000 | Telemóvel: -"
                                   styleClass="section-caption" />
                        </VBox>
                    </HBox>

                    <!-- SECÇÃO 1: Dados do Paciente -->
                    <VBox spacing="10.0" styleClass="patient-info-card"
                          style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 14;">
                        <Label text="Dados do Paciente"
                               styleClass="section-title"
                               style="-fx-font-size: 14px;" />
                        <GridPane hgap="12.0" vgap="6.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120.0" prefWidth="120.0" />
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints minWidth="120.0" prefWidth="120.0" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <children>
                                <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="patient-history-label" />
                                <Label fx:id="lblDadosNome" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="info-title" />
                                <Label text="Data Nasc.:" GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="patient-history-label" />
                                <Label fx:id="lblDadosDataNasc" text="-" GridPane.rowIndex="0" GridPane.columnIndex="3" styleClass="info-title" />

                                <Label text="Idade:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="patient-history-label" />
                                <Label fx:id="lblDadosIdade" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="info-title" />
                                <Label text="NIF:" GridPane.rowIndex="1" GridPane.columnIndex="2" styleClass="patient-history-label" />
                                <Label fx:id="lblDadosNif" text="-" GridPane.rowIndex="1" GridPane.columnIndex="3" styleClass="info-title" />

                                <Label text="Telefone:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="patient-history-label" />
                                <Label fx:id="lblDadosTelefone" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="info-title" />
                                <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="2" styleClass="patient-history-label" />
                                <Label fx:id="lblDadosEmail" text="-" GridPane.rowIndex="2" GridPane.columnIndex="3" styleClass="info-title" />

                                <Label text="Morada:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="patient-history-label" />
                                <Label fx:id="lblDadosMorada" text="-"
                                       GridPane.rowIndex="3" GridPane.columnIndex="1"
                                       GridPane.columnSpan="3"
                                       styleClass="info-title" wrapText="true" />
                            </children>
                        </GridPane>
                    </VBox>

                    <!-- SECÇÃO 2: Informações Médicas -->
                    <VBox spacing="10.0" styleClass="patient-info-card"
                          style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 14;">
                        <Label text="Informações Médicas"
                               styleClass="section-title"
                               style="-fx-font-size: 14px;" />
                        <GridPane hgap="12.0" vgap="6.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120.0" prefWidth="120.0" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <children>
                                <Label text="Alergias:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="patient-history-label" />
                                <Label fx:id="lblMedAlergias" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="info-title" wrapText="true" />

                                <Label text="Medicamentos:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="patient-history-label" />
                                <Label fx:id="lblMedMedicamentos" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="info-title" wrapText="true" />

                                <Label text="Doenças:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="patient-history-label" />
                                <Label fx:id="lblMedDoencas" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="info-title" wrapText="true" />

                                <Label text="Cirurgias:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="patient-history-label" />
                                <Label fx:id="lblMedCirurgias" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="info-title" wrapText="true" />

                                <Label text="Observações:" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="patient-history-label" />
                                <Label fx:id="lblMedObservacoes" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="info-title" wrapText="true" />
                            </children>
                        </GridPane>
                    </VBox>

                    <!-- SECÇÃO 3: Histórico Odontológico -->
                    <VBox spacing="10.0" styleClass="patient-info-card"
                          style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 14;">
                        <Label text="Histórico Odontológico"
                               styleClass="section-title"
                               style="-fx-font-size: 14px;" />
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    prefHeight="160.0" maxHeight="240.0">
                            <TableView fx:id="tblHistoricoConsultas"
                                       styleClass="dashboard-table">
                                <columns>
                                    <TableColumn fx:id="colHistData"       prefWidth="110.0" text="Data" />
                                    <TableColumn fx:id="colHistTipo"       prefWidth="80.0"  text="Tipo" />
                                    <TableColumn fx:id="colHistDentista"   prefWidth="130.0" text="Dentista" />
                                    <TableColumn fx:id="colHistEstado"     prefWidth="90.0"  text="Estado" />
                                    <TableColumn fx:id="colHistDiagnostico" prefWidth="200.0" text="Diagnóstico / Procedimentos" />
                                </columns>
                                <placeholder>
                                    <Label text="Nenhuma consulta anterior registada." styleClass="empty-table-subtitle" />
                                </placeholder>
                            </TableView>
                        </ScrollPane>
                    </VBox>

                    <!-- SECÇÃO 4: Prescrições -->
                    <VBox spacing="10.0" styleClass="patient-info-card"
                          style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 14;">
                        <Label text="Prescrições"
                               styleClass="section-title"
                               style="-fx-font-size: 14px;" />
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    prefHeight="130.0" maxHeight="200.0">
                            <TableView fx:id="tblPrescricoes"
                                       styleClass="dashboard-table">
                                <columns>
                                    <TableColumn fx:id="colPrescData"        prefWidth="90.0"  text="Data" />
                                    <TableColumn fx:id="colPrescMedicamento" prefWidth="190.0" text="Medicamento" />
                                    <TableColumn fx:id="colPrescPosologia"   prefWidth="190.0" text="Posologia" />
                                    <TableColumn fx:id="colPrescDuracao"     prefWidth="100.0" text="Duração" />
                                </columns>
                                <placeholder>
                                    <Label text="Nenhuma prescrição encontrada." styleClass="empty-table-subtitle" />
                                </placeholder>
                            </TableView>
                        </ScrollPane>
                    </VBox>

                    <!-- SECÇÃO 5: Planos de Tratamento -->
                    <VBox spacing="10.0" styleClass="patient-info-card"
                          style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 14;">
                        <Label text="Planos de Tratamento"
                               styleClass="section-title"
                               style="-fx-font-size: 14px;" />
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    prefHeight="130.0" maxHeight="200.0">
                            <TableView fx:id="tblPlanos"
                                       styleClass="dashboard-table">
                                <columns>
                                    <TableColumn fx:id="colPlanoDataInicio" prefWidth="90.0"  text="Data Início" />
                                    <TableColumn fx:id="colPlanoDataFim"    prefWidth="90.0"  text="Data Fim" />
                                    <TableColumn fx:id="colPlanoObjetivo"   prefWidth="190.0" text="Objetivo" />
                                    <TableColumn fx:id="colPlanoEstado"     prefWidth="90.0"  text="Estado" />
                                    <TableColumn fx:id="colPlanoProgresso"  prefWidth="120.0" text="Progresso" />
                                </columns>
                                <placeholder>
                                    <Label text="Nenhum plano de tratamento registado." styleClass="empty-table-subtitle" />
                                </placeholder>
                            </TableView>
                        </ScrollPane>
                    </VBox>

                    <!-- SECÇÃO 6: Anamneses -->
                    <VBox spacing="10.0" styleClass="patient-info-card"
                          style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 14;">
                        <Label text="Anamneses"
                               styleClass="section-title"
                               style="-fx-font-size: 14px;" />
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    prefHeight="130.0" maxHeight="200.0">
                            <TableView fx:id="tblAnamneses"
                                       styleClass="dashboard-table">
                                <columns>
                                    <TableColumn fx:id="colAnamneseData"   prefWidth="110.0" text="Data" />
                                    <TableColumn fx:id="colAnamneseResumo" prefWidth="420.0" text="Resumo" />
                                </columns>
                                <placeholder>
                                    <Label text="Nenhuma anamnese registada." styleClass="empty-table-subtitle" />
                                </placeholder>
                            </TableView>
                        </ScrollPane>
                    </VBox>

                </VBox>
            </StackPane>
        </ScrollPane>

    </HBox>
</VBox>
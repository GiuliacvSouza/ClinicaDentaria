<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<HBox fx:id="loginRoot"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LoginController"
      prefWidth="1280.0" prefHeight="780.0"
      minWidth="980.0" minHeight="640.0"
      styleClass="login-root">

    <StackPane fx:id="imagePanel"
               minWidth="360.0"
               HBox.hgrow="NEVER"
               styleClass="login-image-panel">
        <ImageView fx:id="imgClinica"
                   preserveRatio="true"
                   smooth="true"
                   styleClass="login-image">
            <image>
                <Image url="@../images/rececionistaLogin.png"/>
            </image>
        </ImageView>
        <Region styleClass="login-image-overlay"/>
        <VBox alignment="BOTTOM_LEFT"
              spacing="8.0"
              maxWidth="380.0"
              styleClass="image-copy"
              StackPane.alignment="BOTTOM_LEFT">
            <Label text="Gestão Clínica" styleClass="image-copy-title"/>
            <Label text="Apoio ao atendimento, organização e controlo de stock."
                   wrapText="true"
                   styleClass="image-copy-text"/>
        </VBox>
    </StackPane>

    <VBox fx:id="loginContent"
          alignment="CENTER"
          HBox.hgrow="ALWAYS"
          styleClass="login-content">
        <VBox alignment="CENTER"
              spacing="26.0"
              maxWidth="460.0"
              styleClass="login-column">
            <VBox alignment="CENTER" spacing="4.0">
                <Label text="Clínica Dentária" styleClass="titulo-login"/>
                <Label text="Acesso interno" styleClass="subtitulo-login"/>
                <Label text="Rececionista · Assistente de Consultório" styleClass="perfil-login"/>
            </VBox>

            <VBox spacing="14.0"
                  maxWidth="420.0"
                  minWidth="360.0"
                  styleClass="form-login">
                <VBox spacing="4.0">
                    <Label text="Bem-vinda de volta" styleClass="welcome-login"/>
                    <Label text="Introduza os seus dados para aceder ao portal."
                           wrapText="true"
                           styleClass="description-login"/>
                </VBox>

                <VBox spacing="7.0">
                    <HBox spacing="4.0" alignment="CENTER_LEFT">
                        <Label text="Email" styleClass="label-login"/>
                        <Label text="*" styleClass="label-mandatory"/>
                    </HBox>
                    <TextField fx:id="txtEmail"
                               promptText="seu@email.com"
                               maxWidth="Infinity"
                               styleClass="login-input"/>
                </VBox>

                <VBox spacing="7.0">
                    <HBox spacing="4.0" alignment="CENTER_LEFT">
                        <Label text="Palavra-passe" styleClass="label-login"/>
                        <Label text="*" styleClass="label-mandatory"/>
                    </HBox>
                    <StackPane fx:id="passwordWrapper"
                               maxWidth="Infinity"
                               styleClass="login-input-wrapper">
                        <TextField fx:id="txtPassword"
                                   promptText="••••••••"
                                   maxWidth="Infinity"
                                   styleClass="login-password-inner"/>
                        <Button fx:id="btnTogglePassword"
                                onAction="#togglePasswordVisibility"
                                StackPane.alignment="CENTER_RIGHT"
                                styleClass="password-eye-button">
                            <graphic>
                                <StackPane prefWidth="18.0" prefHeight="18.0">
                                    <SVGPath content="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                                             styleClass="password-eye-icon"/>
                                </StackPane>
                            </graphic>
                        </Button>
                    </StackPane>
                </VBox>

                <Label fx:id="lblErro"
                       text=""
                       styleClass="label-erro"
                       visible="false"
                       managed="false"/>

                <Button fx:id="btnEntrar"
                        text="Entrar"
                        prefHeight="48.0"
                        maxWidth="Infinity"
                        onAction="#handleLogin"
                        styleClass="primary-button">
                    <VBox.margin>
                        <Insets top="2.0"/>
                    </VBox.margin>
                </Button>
            </VBox>
        </VBox>
    </VBox>
</HBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>


<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LoginController"
      prefWidth="1440" prefHeight="1024"
      style="-fx-background-color: white;">

    <!-- ═══ LADO ESQUERDO — Imagem ═══ -->
    <ImageView fx:id="imgClinica"
               fitWidth="668" fitHeight="1024"
               preserveRatio="false">
        <image>
            <Image url="@../images/rececionistaLogin.png"/>
        </image>
    </ImageView>

    <!-- ═══ LADO DIREITO — Formulário ═══ -->
    <VBox alignment="CENTER" spacing="0"
          HBox.hgrow="ALWAYS"
          style="-fx-background-color: white; -fx-padding: 60 80 60 80;">

        <!-- Título principal -->
        <Label text="CLÍNICA DENTÁRIA"
               styleClass="titulo-login"/>

        <!-- Subtítulo -->
        <Label text="Portal Da Rececionista"
               styleClass="subtitulo-login"/>

        <!-- ── Card do formulário ── -->
        <VBox spacing="4"
              styleClass="form-login"
              maxWidth="564" minWidth="450">

            <!-- Bem vinda de volta -->
            <Label text="Bem vinda de volta"
                   styleClass="welcome-login"/>

            <Label text="Entre para aceder o portal"
                   styleClass="description-login"/>

            <!-- Label Email -->
            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="Email"
                       styleClass="label-login"/>
                <Label text="*"
                       styleClass="label-mandatory"/>
            </HBox>

            <!-- Campo Email -->
            <TextField fx:id="txtEmail"
                       promptText="seu@email.com"
                       styleClass="campo-texto"/>

            <!-- Label Palavra-Passe -->
            <HBox spacing="4" alignment="CENTER_LEFT"
                  style="-fx-padding: 8 0 0 0;">
                <Label text="Palavra-Passe"
                       styleClass="label-login"/>
                <Label text="*"
                       styleClass="label-mandatory"/>
            </HBox>

            <!-- Campo Password com ícone de visibilidade -->
            <StackPane>
                <TextField fx:id="txtPassword"
                           promptText="••••••••"
                           styleClass="campo-texto"/>
                <Button fx:id="btnTogglePassword"
                        onAction="#togglePasswordVisibility"
                        StackPane.alignment="CENTER_RIGHT"
                        style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0 10 0 0; -fx-cursor: hand;">
                    <graphic>
                        <StackPane prefWidth="16" prefHeight="16">
                            <javafx.scene.shape.SVGPath content="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" style="-fx-fill: #666; -fx-scale-x: 0.9; -fx-scale-y: 0.9;"/>
                        </StackPane>
                    </graphic>
                </Button>
            </StackPane>

            <!-- Mensagem de erro (invisível por defeito) -->
            <Label fx:id="lblErro"
                   text=""
                   styleClass="label-erro"
                   visible="false"/>

            <!-- Botão ENTRAR -->
            <Button fx:id="btnEntrar"
                    text="ENTRAR"
                    prefHeight="52"
                    maxWidth="Infinity"
                    onAction="#handleLogin"
                    styleClass="primary-button">
                <VBox.margin>
                    <Insets top="8"/>
                </VBox.margin>
            </Button>

        </VBox>
    </VBox>
</HBox>
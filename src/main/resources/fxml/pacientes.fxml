<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #F4F7F6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <children>
                        <Label text="Clínica Dentária" textFill="#3D8B83">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                            <HBox.margin>
                                <Insets left="30.0" right="50.0" />
                            </HBox.margin>
                        </Label>
                        <HBox alignment="CENTER" spacing="30.0">
                            <children>
                                <Button mnemonicParsing="false" style="-fx-background-color: transparent;" text="Agenda">
                                    <font> <Font size="18.0" /> </font>.
                                </Button>
                                <Button mnemonicParsing="false" style="-fx-background-color: #7AB0A9; -fx-text-fill: white; -fx-background-radius: 5;" text="Pacientes">
                                    <font> <Font size="18.0" /> </font>
                                    <padding>
                                        <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
                                    </padding>
                                </Button>
                                <Button mnemonicParsing="false" style="-fx-background-color: transparent;" text="Faturação">
                                    <font> <Font size="18.0" /> </font>
                                </Button>
                            </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <Label text="🔔" />
                                <VBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Label text="Joana Silva" font="$x1">
                                            <font>
                                                <Font name="System Bold" size="14.0" fx:id="x1" />
                                            </font>
                                        </Label>
                                        <Label text="Rececionista" textFill="#757575" />
                                    </children>
                                </VBox>
                                <Label text="🚪">
                                    <HBox.margin>
                                        <Insets right="30.0" />
                                    </HBox.margin>
                                </Label>
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <TextField prefHeight="45.0" prefWidth="700.0" promptText="Pesquisar por nome, NIF ou telemóvel" style="-fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #89CFE0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="+ ADICIONAR PACIENTE" />
                    </children>
                    <padding>
                        <Insets left="30.0" right="30.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tabelaPacientes" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10;" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="colNome" prefWidth="180.0" text="NOME" />
                <TableColumn fx:id="colNif" prefWidth="120.0" text="NIF" />
                <TableColumn fx:id="colSeguro" prefWidth="120.0" text="SEGURO" />
                <TableColumn fx:id="colUltimaVisita" prefWidth="150.0" text="ÚLTIMA VISITA" />
                <TableColumn fx:id="colContacto" prefWidth="250.0" text="CONTACTO" />
                <TableColumn fx:id="colAcoes" prefWidth="100.0" text="AÇÕES" />
            </columns>
            <BorderPane.margin>
                <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
            </BorderPane.margin>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </center>
</BorderPane>